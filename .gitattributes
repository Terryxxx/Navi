# Default: normalize text files to LF in the repo, check out native on each OS
* text=auto eol=lf

# Explicit text formats
*.rs        text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Windows-specific scripts keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary
*.png       binary
*.ico       binary
*.icns      binary
*.wav       binary
*.mp3       binary
*.exe       binary
